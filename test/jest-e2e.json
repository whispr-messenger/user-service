{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/../src/$1",
    "^src/(.*)$": "<rootDir>/../src/$1",
    "^../../privacy/privacy-settings\\.entity$": "<rootDir>/stubs/entity.stub.ts",
    "^../../blocked-users/blocked-user\\.entity$": "<rootDir>/stubs/entity.stub.ts",
    "^../../groups/group\\.entity$": "<rootDir>/stubs/entity.stub.ts",
    "^../../groups/group-member\\.entity$": "<rootDir>/stubs/entity.stub.ts",
    "^../../search/entities/user-search-index\\.entity$": "<rootDir>/stubs/entity.stub.ts"
  },
  "setupFilesAfterEnv": ["<rootDir>/setup-e2e.ts"],
  "testTimeout": 60000,
  "verbose": true
}